{
  "name": "aether",
  "version": "0.1.0",
  "description": "An Electron chat-first collaboration app using Convex and WorkOS AuthKit for dogfood chat.",
  "license": "MIT",
  "author": "",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": "22.23.1"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "pnpm native:macos-auth && electron-vite dev",
    "build": "pnpm native:macos-auth && electron-vite build",
    "convex": "convex",
    "convex:dev": "convex dev",
    "convex:codegen": "convex codegen",
    "convex:check": "tsc -p convex/tsconfig.json --noEmit && node scripts/check-convex-bindings.mjs",
    "dogfood:verify": "pnpm typecheck && pnpm convex:check && pnpm lint && pnpm test && pnpm build",
    "lint": "eslint . && knip",
    "native:macos-auth": "node scripts/build-macos-auth-helper.mjs",
    "start": "electron-vite preview",
    "package:mac": "pnpm build && electron-builder --mac dir --publish never",
    "start:mac": "node scripts/open-packaged-mac.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@convex-dev/workos": "^0.0.3",
    "@workos-inc/authkit-react": "^0.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.42.0",
    "lucide-react": "^1.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0"
  },
  "knip": {
    "entry": [
      "electron.vite.config.ts",
      "src/main/index.ts",
      "src/preload/index.ts",
      "src/renderer/main.tsx",
      "convex/{auth.config,chat,direct_conversations,notification_preferences,schema,social}.ts"
    ],
    "project": [
      "src/**/*.{ts,tsx}",
      "convex/**/*.ts"
    ]
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "convex-test": "^0.0.53",
    "electron": "^41.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^16.0.0",
    "knip": "^6.23.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.11",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.aether.chat",
    "productName": "Aether",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dir",
      "binaries": [
        "Contents/Resources/native/AetherWebAuthHelper.app"
      ]
    },
    "extraResources": [
      {
        "from": "build/native/AetherWebAuthHelper.app",
        "to": "native/AetherWebAuthHelper.app"
      }
    ],
    "protocols": [
      {
        "name": "Aether authentication callback",
        "schemes": ["aether"]
      }
    ]
  }
}
