# Generated by `pnpm convex dev` for local development.
VITE_CONVEX_URL=

# Filled by Convex-managed WorkOS AuthKit setup.
VITE_WORKOS_CLIENT_ID=
VITE_WORKOS_REDIRECT_URI=http://localhost:5173/callback

# Set in Convex with:
# pnpm convex env set AETHER_ALLOWED_EMAILS "you@example.com,friend@example.com"
AETHER_ALLOWED_EMAILS=

# Optional local UI flag for agent development surfaces.
VITE_AETHER_SHOW_AGENT_UI=false
